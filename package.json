{
  "name": "figaf-installer",
  "version": "1.0.0",
  "private": true,
  "description": "Figaf Installer monorepo — Electron desktop installer (figaf-local) and BTP-hosted wizard (figaf-manager)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:local": "npm --workspace apps/figaf-local start",
    "start:manager": "npm --workspace apps/figaf-manager start",
    "build:local": "npm --workspace apps/figaf-local run build:win",
    "build:manager": "npm --workspace apps/figaf-manager run build-zip"
  },
  "dependencies": {
    "@sap/approuter": "^16.9.0"
  }
}
