{
  "name": "figaf-local",
  "version": "26.5.0",
  "private": true,
  "description": "Figaf Installer — Electron desktop wizard for SAP BTP Cloud Foundry deployment",
  "main": "main-process/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "node scripts/build-win.js"
  },
  "author": "Figaf",
  "license": "UNLICENSED",
  "dependencies": {
    "@figaf/core": "*",
    "@figaf/deploy-templates": "*",
    "@figaf/ui": "*"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.figaf.installer",
    "productName": "Figaf Installer",
    "asar": true,
    "icon": "../../packages/ui/favicon.png",
    "files": [
      "main-process/**/*",
      "node_modules/@figaf/core/**/*",
      "node_modules/@figaf/ui/**/*"
    ],
    "extraResources": [
      {
        "from": "../../packages/deploy-templates",
        "to": "deploy-templates",
        "filter": [
          "**/*",
          "!package.json"
        ]
      },
      {
        "from": "../../instructions.md",
        "to": "instructions.md"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Figaf Installer",
      "artifactName": "Figaf-Installer-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Figaf-Installer-${version}-${arch}.${ext}"
    }
  }
}
